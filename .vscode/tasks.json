{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Install venv packages",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "pip",
                "install",
                "-r",
                ".install_venv"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run doorstop-edit",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "doorstop_edit"
            ],
            "isBackground": false,
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Generate documents",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            // "command": "doorstop",
            "args": [
                // "-m",
                "doorstop",
                "publish",
                "--html",
                "${input:doctype}",
                "./out"
            ],
            "isBackground": false,
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        }
    ],
    "inputs": [
        {
            "id": "doctype",
            "type": "pickString",
            "description": "Select document type",
            "options": [
                "REQ",
                "SPEC",
                "TST",
                "all"
            ],
            "default": "REQ"
        }
    ],
}